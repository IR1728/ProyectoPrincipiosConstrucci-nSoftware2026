<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="520.0" prefWidth="760.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sgpp.controlador.LoginController">
    <top>
        <VBox spacing="8.0" style="-fx-background-color: #263238; -fx-padding: 16;">
            <Label text="Sistema de Gestion de Practicas Profesionales" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
            <Label fx:id="lblMensaje" textFill="#ECEFF1" />
        </VBox>
    </top>
    <center>
        <VBox maxWidth="420.0" spacing="10.0" style="-fx-padding: 24; -fx-border-color: #B0BEC5; -fx-border-radius: 4;">
            <Label text="Inicio de sesion" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            <Label text="Usuario" />
            <TextField fx:id="txtUsuario" />
            <Label text="Contrasena" />
            <PasswordField fx:id="txtContrasena" />
            <Button text="Iniciar sesion" onAction="#iniciarSesion" maxWidth="Infinity" />
        </VBox>
    </center>
</BorderPane>
