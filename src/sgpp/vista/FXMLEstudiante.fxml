<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="820.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sgpp.controlador.EstudianteController">
    <top>
        <VBox spacing="8.0" style="-fx-background-color: #263238; -fx-padding: 16;">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label text="SGPP - Estudiante" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                <Label fx:id="lblSesion" textFill="#CFD8DC" />
                <Button text="Cerrar sesion" onAction="#cerrarSesion" />
            </HBox>
            <Label fx:id="lblMensaje" textFill="#ECEFF1" />
        </VBox>
    </top>
    <center>
        <VBox spacing="8.0" style="-fx-padding: 18;">
            <Label text="CU15 Llenar Autoevaluacion" style="-fx-font-size: 15; -fx-font-weight: bold;" />
            <Label text="Puntaje 1-100" />
            <TextField fx:id="txtPuntajeAutoevaluacion" />
            <Label text="Comentarios" />
            <TextArea fx:id="txtComentariosAutoevaluacion" prefRowCount="5" />
            <Button text="Subir autoevaluacion" onAction="#registrarAutoevaluacion" />
        </VBox>
    </center>
</BorderPane>
