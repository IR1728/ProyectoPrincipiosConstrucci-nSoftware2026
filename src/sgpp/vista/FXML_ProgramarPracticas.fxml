<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="840.0"
            style="-fx-background-color: linear-gradient(to bottom right, #15546b, #2e8b41);"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sgpp.controlador.ProgramarPracticasController">
    <children>
        <Label layoutX="28.0" layoutY="22.0"
               text="Programar Entregas de Practicas Profesionales" textFill="#ffffff">
            <font>
                <Font name="Arial Bold Italic" size="22.0" />
            </font>
        </Label>

        <Pane layoutX="24.0" layoutY="70.0" prefHeight="500.0" prefWidth="792.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 26;">
            <children>
                <Label layoutX="44.0" layoutY="18.0"
                       text="Todos los campos son obligatorios: indica fecha de apertura y limite de cada entrega."
                       textFill="#5a5a5a">
                    <font>
                        <Font name="Arial Italic" size="13.0" />
                    </font>
                </Label>

                <GridPane hgap="18.0" layoutX="44.0" layoutY="50.0" prefWidth="704.0" vgap="8.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="240.0" prefWidth="260.0" />
                        <ColumnConstraints minWidth="200.0" prefWidth="210.0" />
                        <ColumnConstraints minWidth="200.0" prefWidth="210.0" />
                    </columnConstraints>
                    <children>
                        <Label text="Entrega" textFill="#14506b" GridPane.rowIndex="0">
                            <font>
                                <Font name="Arial Bold" size="14.0" />
                            </font>
                        </Label>
                        <Label text="Fecha de apertura" textFill="#14506b"
                               GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <font>
                                <Font name="Arial Bold" size="14.0" />
                            </font>
                        </Label>
                        <Label text="Fecha limite" textFill="#14506b" GridPane.columnIndex="2"
                               GridPane.rowIndex="0">
                            <font>
                                <Font name="Arial Bold" size="14.0" />
                            </font>
                        </Label>

                        <Label text="Documento inicial" GridPane.rowIndex="1" />
                        <DatePicker fx:id="aperturaDocumentoInicial" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <DatePicker fx:id="limiteDocumentoInicial" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="1" />

                        <Label text="Documento parcial" GridPane.rowIndex="2" />
                        <DatePicker fx:id="aperturaDocumentoParcial" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <DatePicker fx:id="limiteDocumentoParcial" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="2" />

                        <Label text="Documento final" GridPane.rowIndex="3" />
                        <DatePicker fx:id="aperturaDocumentoFinal" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <DatePicker fx:id="limiteDocumentoFinal" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="3" />

                        <Label text="Reporte mensual 1" GridPane.rowIndex="4" />
                        <DatePicker fx:id="aperturaReporteUno" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <DatePicker fx:id="limiteReporteUno" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="4" />

                        <Label text="Reporte mensual 2" GridPane.rowIndex="5" />
                        <DatePicker fx:id="aperturaReporteDos" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <DatePicker fx:id="limiteReporteDos" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="5" />

                        <Label text="Reporte mensual 3" GridPane.rowIndex="6" />
                        <DatePicker fx:id="aperturaReporteTres" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <DatePicker fx:id="limiteReporteTres" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="6" />

                        <Label text="Reporte mensual 4" GridPane.rowIndex="7" />
                        <DatePicker fx:id="aperturaReporteCuatro" prefWidth="200.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="7" />
                        <DatePicker fx:id="limiteReporteCuatro" prefWidth="200.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="7" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" layoutX="44.0" layoutY="430.0" prefWidth="704.0"
                      spacing="18.0">
                    <children>
                        <Button onAction="#clicSalir" text="Salir" textFill="#b03a2e"
                                style="-fx-background-color: #ffffff; -fx-border-color: #b03a2e; -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-padding: 8 26 8 26; -fx-cursor: hand;" />
                        <Button onAction="#clicCancelar" text="Cancelar" textFill="#2a2a2a"
                                style="-fx-background-color: #e0e6e8; -fx-background-radius: 18; -fx-padding: 8 26 8 26; -fx-cursor: hand;" />
                        <Button onAction="#clicGuardar" text="Guardar" textFill="#ffffff"
                                style="-fx-background-color: #14506b; -fx-background-radius: 18; -fx-padding: 8 26 8 26; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
        </Pane>
    </children>
</AnchorPane>
