<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="406.0" prefWidth="622.0"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sgpp.controlador.InicioSesionController">
   <children>

      <!-- ═══════════════════════════════════════════════ -->
      <!--  MITAD IZQUIERDA — Panel de imagen              -->
      <!-- ═══════════════════════════════════════════════ -->
      <Pane layoutX="0.0" layoutY="0.0" prefHeight="406.0" prefWidth="311.0"
            style="-fx-background-color: linear-gradient(to bottom, #0d3b6e, #1a6e3c);">
         <children>

            <!-- Logo centrado verticalmente -->
            <ImageView fitHeight="220.0" fitWidth="220.0" layoutX="45.0" layoutY="93.0"
                       pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../recursos/universidad-veracruzana-logo-uv.png" />
               </image>
            </ImageView>

            <!-- Texto institucional debajo del logo -->
            <Label alignment="CENTER" layoutX="0.0" layoutY="325.0" prefWidth="311.0"
                   style="-fx-opacity: 0.85;" text="Universidad Veracruzana" textFill="WHITE">
               <font><Font name="System Bold" size="13.0" /></font>
            </Label>

         </children>
      </Pane>

      <!-- ═══════════════════════════════════════════════ -->
      <!--  MITAD DERECHA — Panel de inicio de sesión      -->
      <!-- ═══════════════════════════════════════════════ -->
      <Pane layoutX="311.0" layoutY="0.0" prefHeight="406.0" prefWidth="311.0"
            style="-fx-background-color: #f4f8f4;">
         <children>

            <!-- Título -->
            <Label alignment="CENTER" layoutX="0.0" layoutY="30.0" prefHeight="33.0"
                   prefWidth="311.0" text="Sistema de practicas profesionales"
                   textFill="#0d3b6e">
               <font><Font name="System Bold" size="22.0" /></font>
            </Label>

            <!-- Subtítulo instrucciones -->
            <Label alignment="CENTER" layoutX="20.0" layoutY="68.0" prefWidth="271.0"
                   text="Ingresa tu número de personal y contraseña para continuar."
                   textAlignment="CENTER" textFill="#555555" wrapText="true">
               <font><Font size="12.0" /></font>
            </Label>

            <!-- Separador decorativo -->
            <Pane layoutX="130.0" layoutY="118.0" prefHeight="3.0" prefWidth="50.0"
                  style="-fx-background-color: #1a6e3c; -fx-background-radius: 2;" />

            <!-- Label Número de personal -->
            <Label layoutX="30.0" layoutY="135.0" text="Número de personal" textFill="#0d3b6e">
               <font><Font name="System Bold" size="12.0" /></font>
            </Label>

            <!-- TextField número de personal -->
            <TextField fx:id="campoNumeroPersonal" layoutX="30.0" layoutY="155.0"
                       prefHeight="34.0" prefWidth="251.0" promptText="jperez001"
                       style="-fx-background-radius: 6; -fx-border-color: #1a6e3c; -fx-border-radius: 6; -fx-border-width: 1.5; -fx-background-color: white; -fx-padding: 0 8 0 8;" />

            <!-- Label Contraseña -->
            <Label layoutX="30.0" layoutY="200.0" text="Contraseña" textFill="#0d3b6e">
               <font><Font name="System Bold" size="12.0" /></font>
            </Label>

            <!-- PasswordField -->
            <PasswordField fx:id="campoContrasena" layoutX="30.0" layoutY="220.0"
                           prefHeight="34.0" prefWidth="251.0" promptText="••••••"
                           style="-fx-background-radius: 6; -fx-border-color: #1a6e3c; -fx-border-radius: 6; -fx-border-width: 1.5; -fx-background-color: white; -fx-padding: 0 8 0 8;" />

            <!-- Label de error -->
            <Label fx:id="etiquetaError" alignment="CENTER" layoutX="30.0" layoutY="258.0"
                   prefHeight="16.0" prefWidth="251.0" textAlignment="CENTER"
                   textFill="#bb1616">
               <font><Font name="System Bold" size="11.0" /></font>
            </Label>

            <!-- Botón Acceder -->
            <Button onAction="#clicAcceder" layoutX="95.0" layoutY="290.0"
                    mnemonicParsing="false" prefHeight="36.0" prefWidth="121.0"
                    text="Acceder"
                    style="-fx-background-color: linear-gradient(to right, #0d3b6e, #1a6e3c); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-cursor: hand;" />

         </children>
      </Pane>

   </children>
</AnchorPane>
